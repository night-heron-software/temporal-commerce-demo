# =============================================================================
# Temporal Commerce Demo — Environment Configuration
# =============================================================================
# Copy this to .env.local and adjust as needed.
# Default values are set for local Docker Compose development.

# === Temporal ===
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
# For Temporal Cloud, uncomment and configure:
# TEMPORAL_ADDRESS=your-namespace.tmprl.cloud:7233
# TEMPORAL_NAMESPACE=your-namespace
# TEMPORAL_TLS_CERT=<base64-encoded-cert>
# TEMPORAL_TLS_KEY=<base64-encoded-key>

# === Cassandra ===
CASSANDRA_CONTACT_POINTS=localhost:9042
CASSANDRA_KEYSPACE=catalog
# For Astra DB or AWS Keyspaces, uncomment and configure:
# CASSANDRA_USE_TLS=true
# CASSANDRA_SECURE_BUNDLE_PATH=./secure-connect-bundle.zip

# === Elasticsearch ===
ELASTICSEARCH_URL=http://localhost:9200
# For Elastic Cloud or Amazon OpenSearch:
# ELASTICSEARCH_URL=https://your-cluster.es.us-east-1.aws.found.io
# ELASTICSEARCH_API_KEY=your-api-key

# === Application ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
