# === Local Development (defaults — works with docker-compose.yml) ===
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
CASSANDRA_CONTACT_POINTS=localhost:9042
CASSANDRA_KEYSPACE=catalog
ELASTICSEARCH_URL=http://localhost:9200

# === Temporal Cloud (uncomment for cloud deployment) ===
# TEMPORAL_ADDRESS=your-namespace.tmprl.cloud:7233
# TEMPORAL_NAMESPACE=your-namespace
# TEMPORAL_TLS_CERT=<base64-encoded-cert>
# TEMPORAL_TLS_KEY=<base64-encoded-key>

# === Cloud Cassandra (Astra DB or AWS Keyspaces) ===
# CASSANDRA_CONTACT_POINTS=xxx.astra.datastax.com:29042
# CASSANDRA_USE_TLS=true
# CASSANDRA_SECURE_BUNDLE_PATH=./secure-connect-bundle.zip

# === Cloud Elasticsearch (Amazon OpenSearch or Elastic Cloud) ===
# ELASTICSEARCH_URL=https://xxx.us-east-1.es.amazonaws.com
# ELASTICSEARCH_API_KEY=xxx

# === Application ===
NEXTAUTH_SECRET=dev-secret-change-me
NEXT_PUBLIC_APP_URL=http://localhost:3000
INIT_SECRET=dev-init-secret
