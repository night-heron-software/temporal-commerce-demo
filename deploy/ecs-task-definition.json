{
  "family": "temporal-commerce-worker",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "${EXECUTION_ROLE_ARN}",
  "taskRoleArn": "${TASK_ROLE_ARN}",
  "containerDefinitions": [
    {
      "name": "worker",
      "image": "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/temporal-commerce-worker:latest",
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/temporal-commerce-worker",
          "awslogs-region": "${AWS_REGION}",
          "awslogs-stream-prefix": "worker"
        }
      },
      "environment": [
        { "name": "NODE_ENV", "value": "production" }
      ],
      "secrets": [
        { "name": "TEMPORAL_ADDRESS", "valueFrom": "arn:aws:ssm:${AWS_REGION}:${AWS_ACCOUNT_ID}:parameter/temporal-commerce/TEMPORAL_ADDRESS" },
        { "name": "TEMPORAL_NAMESPACE", "valueFrom": "arn:aws:ssm:${AWS_REGION}:${AWS_ACCOUNT_ID}:parameter/temporal-commerce/TEMPORAL_NAMESPACE" },
        { "name": "TEMPORAL_TLS_CERT", "valueFrom": "arn:aws:ssm:${AWS_REGION}:${AWS_ACCOUNT_ID}:parameter/temporal-commerce/TEMPORAL_TLS_CERT" },
        { "name": "TEMPORAL_TLS_KEY", "valueFrom": "arn:aws:ssm:${AWS_REGION}:${AWS_ACCOUNT_ID}:parameter/temporal-commerce/TEMPORAL_TLS_KEY" },
        { "name": "CASSANDRA_CONTACT_POINTS", "valueFrom": "arn:aws:ssm:${AWS_REGION}:${AWS_ACCOUNT_ID}:parameter/temporal-commerce/CASSANDRA_CONTACT_POINTS" },
        { "name": "CASSANDRA_KEYSPACE", "valueFrom": "arn:aws:ssm:${AWS_REGION}:${AWS_ACCOUNT_ID}:parameter/temporal-commerce/CASSANDRA_KEYSPACE" },
        { "name": "CASSANDRA_USE_TLS", "valueFrom": "arn:aws:ssm:${AWS_REGION}:${AWS_ACCOUNT_ID}:parameter/temporal-commerce/CASSANDRA_USE_TLS" },
        { "name": "ELASTICSEARCH_URL", "valueFrom": "arn:aws:ssm:${AWS_REGION}:${AWS_ACCOUNT_ID}:parameter/temporal-commerce/ELASTICSEARCH_URL" },
        { "name": "ELASTICSEARCH_API_KEY", "valueFrom": "arn:aws:ssm:${AWS_REGION}:${AWS_ACCOUNT_ID}:parameter/temporal-commerce/ELASTICSEARCH_API_KEY" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "pgrep -f worker.ts > /dev/null || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 15
      }
    }
  ]
}
