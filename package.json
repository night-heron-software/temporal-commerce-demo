{
  "name": "temporal-commerce-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "dev:up": "concurrently --names \"storefront,workers\" --prefix-colors \"cyan,magenta\" --kill-others-on-fail \"npm run dev:storefront\" \"npm run dev:worker\"",
    "dev:down": "bash scripts/stop-dev.sh",
    "dev:stop-all": "npm run dev:down && npm run infra:down",
    "dev:start-all": "npm run infra:up && npm run dev:up",
    "dev:status": "bash scripts/status.sh",
    "dev:init": "bash scripts/init.sh",
    "dev:storefront": "npm run dev",
    "dev:worker": "tsx --env-file=.env.local ./src/temporal/worker.ts",
    "db:init": "docker exec -i demo-cassandra cqlsh < cassandra/schema.cql && echo '✓ Schema initialized'",
    "dev:seed": "tsx --env-file=.env.local ./scripts/seed.ts",
    "db:verify": "bash scripts/verify-schema.sh",
    "infra:up": "bash scripts/infra-start.sh",
    "infra:down": "bash scripts/local-shutdown.sh",
    "infra:clean": "npm run infra:down && docker-compose down -v && echo '✓ All data wiped'",
    "infra:ps": "docker-compose ps",
    "infra:ready": "bash scripts/docker-ready.sh"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.19.1",
    "@temporalio/activity": "^1.17.0",
    "@temporalio/client": "^1.17.0",
    "@temporalio/common": "^1.17.0",
    "@temporalio/worker": "^1.17.0",
    "@temporalio/workflow": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "cassandra-driver": "^4.8.0",
    "next": "16.2.4",
    "pino": "^10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "npm-run-all": "^4.1.5",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
